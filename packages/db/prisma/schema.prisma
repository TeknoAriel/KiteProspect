// Kite Prospect - Esquema de base de datos
// Fuente de verdad: PRODUCT_DEFINITION.md

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================================================
// TENANCY / CUENTAS
// =============================================================================

model Account {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  status    String   @default("active") // active, suspended, trial
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Configuración básica por cuenta
  config Json? // settings comercialmente configurables

  users         User[]
  advisors      Advisor[]
  contacts      Contact[]
  properties    Property[]
  conversations Conversation[]
  integrations  Integration[]
  followUpPlans FollowUpPlan[]
  auditEvents   AuditEvent[]
  captureApiKeys CaptureApiKey[]
  webhookSubscriptions WebhookSubscription[]
  branches      Branch[]
  simulationRuns SimulationRun[]
  leads         Lead[]
  channelStates ChannelState[]
  ingestionIdempotencyKeys IngestionIdempotencyKey[]
  handoffOutboundAttempts HandoffOutboundAttempt[]
  kitepropLeadSyncRuns     KitepropLeadSyncRun[]
  kitepropLeadSyncCursor   KitepropLeadSyncCursor?
  leadReplyDraftReviews    LeadReplyDraftReview[]
}

/// Ejecución de sync desde KiteProp REST API (importación validación).
model KitepropLeadSyncRun {
  id        String    @id @default(cuid())
  accountId String
  startedAt DateTime  @default(now())
  completedAt DateTime?
  /// running | completed | failed
  status    String    @default("running")
  lookbackDays Int    @default(7)
  fetchedCount  Int @default(0)
  importedCount Int @default(0)
  skippedCount  Int @default(0)
  dedupedCount    Int @default(0)
  errorCount      Int @default(0)
  errorMessage    String? @db.VarChar(2000)
  rawPayloadSnapshot Json?

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId, startedAt(sort: Desc)])
}

/// Cursor opaco para paginación incremental con la API externa.
model KitepropLeadSyncCursor {
  accountId             String    @id
  lastSuccessfulEndAt DateTime?
  opaqueCursor        String?   @db.VarChar(4000)

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)
}

/// Cola de revisión humana: respuestas sugeridas (sin envío automático en review mode).
model LeadReplyDraftReview {
  id        String   @id @default(cuid())
  accountId String
  leadId    String   @unique
  contactId String
  /// draft_pending_review | manual_review_required | approved_to_send | sent | discarded (imported_real_lead reservado / futuro pipeline async)
  reviewStatus String
  sourceChannel String?
  sourcePortal  String?
  channelConfidence Float?
  externalPropertyRef Json?
  propertyId String?
  /// whatsapp | email | portal | none
  draftKind  String?
  draftPayload Json?
  editedPayload Json?
  manualReviewRequired Boolean @default(false)
  approvedByUserId String?
  approvedAt DateTime?
  sentAt     DateTime?
  discardedAt DateTime?
  discardedReason String? @db.VarChar(2000)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  account  Account  @relation(fields: [accountId], references: [id], onDelete: Cascade)
  lead     Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  contact  Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  property Property? @relation(fields: [propertyId], references: [id], onDelete: SetNull)

  @@index([accountId, reviewStatus])
  @@index([contactId])
}

/// Reporte de laboratorio: 20 escenarios conversacionales + snapshot de seguimiento (tester).
model SimulationRun {
  id        String   @id @default(cuid())
  accountId String
  label     String   @default("Laboratorio 20 escenarios")
  payload   Json
  createdAt DateTime @default(now())

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId, createdAt])
}

/// Sucursal / unidad operativa dentro del tenant (F3-E4 / L15 MVP).
model Branch {
  id        String   @id @default(cuid())
  accountId String
  name      String
  slug      String
  status    String   @default("active") // active, archived
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  account  Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  contacts Contact[]
  advisors Advisor[]

  @@unique([accountId, slug])
  @@index([accountId])
}

/// API key por tenant para `POST /api/contacts/create` (F3-E2). Secreto completo `kp_<prefix>_<suffix>`; solo se guarda hash.
model CaptureApiKey {
  id        String   @id @default(cuid())
  accountId String
  name      String?
  keyPrefix String   @unique
  keyHash   String
  createdAt DateTime @default(now())
  revokedAt DateTime?

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
}

/// Destino de webhooks salientes firmados (F3-E3 / L14). El secreto se muestra una vez al crear; se guarda en claro para firmar HMAC en cada entrega (MVP).
model WebhookSubscription {
  id        String   @id @default(cuid())
  accountId String
  name      String?
  url       String
  signingSecret String
  /// JSON array de eventos: ver WEBHOOK_EVENT_TYPES (apps/web)
  events    Json     @default("[\"lead.captured\",\"contact.assignment_changed\",\"contact.stages_updated\",\"follow_up.sequence_started\",\"contact.external_id_updated\"]")
  createdAt DateTime @default(now())
  revokedAt DateTime?

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
}

model User {
  id        String   @id @default(cuid())
  accountId String
  email     String
  password  String   // hasheado con bcrypt
  name      String?
  role      String   // admin, coordinator, advisor
  status    String   @default("active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  account  Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  advisors Advisor[]

  @@unique([accountId, email])
}

model Advisor {
  id        String   @id @default(cuid())
  accountId String
  userId    String?
  /// Sucursal operativa (F3-E4++): si está definida, el usuario asesor vinculado solo ve contactos de esa sucursal o sin sucursal.
  branchId  String?
  name      String
  email     String?
  phone     String?
  status    String   @default("active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  account     Account      @relation(fields: [accountId], references: [id], onDelete: Cascade)
  branch      Branch?      @relation(fields: [branchId], references: [id], onDelete: SetNull)
  user        User?        @relation(fields: [userId], references: [id])
  assignments Assignment[]

  @@index([accountId, branchId])
}

// =============================================================================
// CONTACTOS Y CONVERSACIONES
// =============================================================================

model Contact {
  id        String   @id @default(cuid())
  accountId String
  branchId  String?

  // Identificación
  email     String?
  phone     String?
  name      String?
  externalId String? // ID en CRM externo

  // Perfil declarado (Fase 1)
  declaredProfile Json?

  // Estados del funnel
  conversationalStage String @default("new") // new, answered, identified, profiled_partial, profiled_useful, consent_obtained, followup_active
  commercialStage     String @default("exploratory") // exploratory, prospect, real_lead, blocked, hot, assigned, visit_scheduled, opportunity_active, paused, lost, won

  /// Integración CRM (p. ej. KiteProp API): payload complementario no mapeado a columnas; ver docs/kiteprop-unified-data-model.md
  metadata Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  account        Account          @relation(fields: [accountId], references: [id], onDelete: Cascade)
  branch         Branch?         @relation(fields: [branchId], references: [id], onDelete: SetNull)
  conversations  Conversation[]
  searchProfiles SearchProfile[]
  leadScores     LeadScore[]
  leadQualifications LeadQualification[]
  consents       Consent[]
  tasks          Task[]
  notes          Note[]
  assignments    Assignment[]
  recommendations Recommendation[]
  propertyMatches PropertyMatch[]
  followUpSequences FollowUpSequence[]
  leads           Lead[]
  channelStates   ChannelState[]
  leadReplyDraftReviews LeadReplyDraftReview[]

  /// Un mismo ID de CRM no puede repetirse por cuenta (varias filas con externalId null sí).
  @@unique([accountId, externalId])
}

/// Unidad de captación / handoff hacia CRM externo (Prospect ≠ pipeline KiteProp completo).
model Lead {
  id        String   @id @default(cuid())
  accountId String
  contactId String

  /// open | qualified | handed_off | archived
  status         String   @default("open")
  source         String   @default("form")
  campaignId     String?
  archivedReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)
  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  conversations Conversation[]
  leadScores    LeadScore[]
  leadQualifications LeadQualification[]
  leadReplyDraftReview LeadReplyDraftReview?

  @@index([accountId, contactId])
  @@index([contactId, status])
}

/// Estado operativo por canal (ventanas WA, cooldowns, contadores).
model ChannelState {
  id        String   @id @default(cuid())
  accountId String
  contactId String
  channel   String

  lastInboundAt  DateTime?
  lastOutboundAt DateTime?
  /// Fin de ventana de sesión WA (24h desde último inbound del usuario).
  waSessionExpiresAt DateTime?
  lastEmailFollowUpAt DateTime?
  outboundCount24h    Int       @default(0)

  metadata  Json?
  updatedAt DateTime @updatedAt

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)
  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([accountId, contactId, channel])
  @@index([accountId])
}

/// Dedup de ingesta (form, webhooks).
model IngestionIdempotencyKey {
  id        String   @id @default(cuid())
  accountId String
  /// capture | wa_webhook | campaign_mock | kiteprop_rest
  source    String
  key       String

  contactId String?
  leadId    String?

  createdAt DateTime @default(now())

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([accountId, source, key])
  @@index([accountId])
}

model Conversation {
  id        String   @id @default(cuid())
  accountId String
  contactId String
  /// Lead activo asociado (captación / seguimiento).
  leadId    String?

  channel   String   // web_widget, landing, whatsapp, form
  channelId String?  // ID externo del canal (ej: wa_id)
  status    String   @default("active") // active, closed, archived

  /// Última vez que el equipo abrió el hilo en inbox (no afecta orden por updatedAt si se actualiza vía SQL raw).
  lastReadAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  account   Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  contact   Contact   @relation(fields: [contactId], references: [id], onDelete: Cascade)
  lead      Lead?     @relation(fields: [leadId], references: [id], onDelete: SetNull)
  messages  Message[]

  @@index([leadId])
}

model Message {
  id             String   @id @default(cuid())
  conversationId String

  direction String  // inbound, outbound
  content   String
  channel   String  // web, whatsapp, etc.

  // WhatsApp: estados, plantillas, costos
  status       String?  // sent, delivered, read, failed
  templateId   String?
  metadata     Json?

  createdAt DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}

// =============================================================================
// PERFIL Y MATCHING
// =============================================================================

model SearchProfile {
  id        String   @id @default(cuid())
  contactId String

  // Perfil de búsqueda declarado/inferido
  intent      String?   // compra, renta, inversión
  propertyType String?  // departamento, casa, terreno
  zone        String?
  minPrice    Decimal?  @db.Decimal(15, 2)
  maxPrice    Decimal?  @db.Decimal(15, 2)
  bedrooms    Int?
  bathrooms   Int?
  extra       Json?     // requisitos adicionales
  source      String    @default("declared") // declared, inferred
  confidence  Float?    // 0-1 para inferidos

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
}

model Property {
  id        String   @id @default(cuid())
  accountId String

  title       String
  description String?
  type        String   // departamento, casa, terreno
  intent      String   // venta, renta
  zone        String?
  address     String?
  price       Decimal  @db.Decimal(15, 2)
  bedrooms    Int?
  bathrooms   Int?
  area        Decimal? @db.Decimal(10, 2)
  status      String   @default("available") // available, reserved, sold, rented, withdrawn

  // Ingesta KiteProp / portales (XML full + JSON delta Proppit)
  externalSource    String? // p.ej. kiteprop
  externalId        String? // id en el feed
  importFingerprint String? // sha256 payload estable; evita escrituras si no cambió
  amenities         Json? // mapa nombre → boolean o estructura del portal
  city              String?
  province          String?
  country           String?   @default("AR")
  currency          String?   @default("ARS")
  surfaceTotal      Decimal?  @db.Decimal(12, 2)
  surfaceCovered    Decimal?  @db.Decimal(12, 2)
  rooms             Int? // ambientes
  latitude          Decimal?  @db.Decimal(12, 9)
  longitude         Decimal?  @db.Decimal(12, 9)
  feedLastSeenAt    DateTime?
  feedRemovedAt     DateTime?
  // Fecha/hora de última modición reportada por el feed (JSON/XML), si viene en el aviso.
  externalFeedUpdatedAt DateTime?

  metadata Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  account        Account          @relation(fields: [accountId], references: [id], onDelete: Cascade)
  propertyMatches PropertyMatch[]
  recommendations Recommendation[]
  leadReplyDraftReviews LeadReplyDraftReview[]

  @@index([accountId, externalSource])
  @@unique([accountId, externalSource, externalId], name: "property_account_external_key")
}

model PropertyMatch {
  id         String   @id @default(cuid())
  contactId  String
  propertyId String

  score      Float    // 0-100 matching score
  reason     String?  // por qué coincide
  sentAt     DateTime? // cuándo se recomendó
  feedback   String?  // interested, not_interested, viewed

  createdAt DateTime @default(now())

  contact  Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([contactId, propertyId])
}

model Recommendation {
  id         String   @id @default(cuid())
  contactId  String
  propertyId String

  channel    String   // whatsapp, email, widget
  status     String   @default("sent") // sent, delivered, opened, clicked
  sentAt     DateTime @default(now())

  contact  Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
}

// =============================================================================
// SCORING Y CALIFICACIÓN
// =============================================================================

model LeadScore {
  id        String   @id @default(cuid())
  contactId String
  leadId    String?

  // Sub-scores (0-100 cada uno)
  intentScore     Float @default(0)
  readinessScore  Float @default(0)
  fitScore        Float @default(0)
  engagementScore Float @default(0)

  totalScore Float @default(0) // combinación ponderada
  version    Int   @default(1)

  createdAt DateTime @default(now())

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  lead    Lead?   @relation(fields: [leadId], references: [id], onDelete: SetNull)

  @@index([leadId])
}

model LeadQualification {
  id        String   @id @default(cuid())
  contactId String
  leadId    String?

  qualified  Boolean
  reason     String?
  criteria   Json?   // detalle de criterios aplicados
  source     String  // rule, ai, manual

  createdAt DateTime @default(now())

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  lead    Lead?   @relation(fields: [leadId], references: [id], onDelete: SetNull)

  @@index([leadId])
}

/// Log de intentos HTTP hacia KiteProp (handoff lead.qualified): trazabilidad e idempotencia operativa.
model HandoffOutboundAttempt {
  id                String   @id @default(cuid())
  accountId         String
  leadId            String
  contactId         String
  dedupeKey         String
  eventId           String
  attemptNumber     Int      @default(1)
  targetUrl         String
  httpStatus        Int?
  ok                Boolean  @default(false)
  latencyMs         Int?
  requestBodySha256 String?
  /// JSON truncado del body enviado (operación / replay); sin PII adicional al payload ya estructurado.
  requestPayloadSnapshot String? @db.VarChar(8000)
  responseSnippet   String?  @db.VarChar(4000)
  errorMessage      String?  @db.VarChar(2000)

  createdAt DateTime @default(now())

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId, createdAt(sort: Desc)])
  @@index([leadId, createdAt(sort: Desc)])
}

// =============================================================================
// SEGUIMIENTO
// =============================================================================

model FollowUpPlan {
  id        String   @id @default(cuid())
  accountId String

  name        String
  description String?
  /// Intensidad oficial: soft | normal | strong | priority (legacy en datos: low | medium | high).
  intensity   String   @default("normal")
  maxAttempts Int     @default(10)
  sequence    Json    // pasos configurables
  triggers    Json?   // cuándo activar (score, stage, etc.)
  reactivateOnNewProperties Boolean @default(false)

  status    String   @default("active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  account  Account           @relation(fields: [accountId], references: [id], onDelete: Cascade)
  sequences FollowUpSequence[]
}

model FollowUpSequence {
  id             String   @id @default(cuid())
  contactId      String
  followUpPlanId String

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  status       String   @default("active") // active, paused, completed, closed
  currentStep  Int      @default(0)
  attempts     Int      @default(0)
  nextAttemptAt DateTime?

  /// Etapa del núcleo (6) del próximo paso pendiente; al completar, última etapa ejecutada.
  matrixCoreStageKey String?
  /// Rama automática vigente (motor evolutivo); opcional hasta reglas completas.
  matrixBranchKey    String?
  /// Si true, el cron no sobrescribe `matrixBranchKey` con la inferencia.
  matrixBranchLocked Boolean @default(false)

  startedAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  plan    FollowUpPlan    @relation(fields: [followUpPlanId], references: [id], onDelete: Cascade)
  attemptsList FollowUpAttempt[]
}

model FollowUpAttempt {
  id         String   @id @default(cuid())
  sequenceId String

  step       Int
  channel    String
  objective  String?  // objetivo del intento
  outcome    String?  // success, no_response, opt_out, etc.
  metadata   Json?

  attemptedAt DateTime @default(now())

  sequence FollowUpSequence @relation(fields: [sequenceId], references: [id], onDelete: Cascade)
}

// =============================================================================
// CONSENTIMIENTO
// =============================================================================

model Consent {
  id        String   @id @default(cuid())
  contactId String

  channel   String   // whatsapp, email, etc.
  granted   Boolean
  grantedAt DateTime?
  revokedAt DateTime?
  purpose   String?  // marketing, followup, etc.

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
}

// =============================================================================
// CRM BÁSICO
// =============================================================================

model Task {
  id        String   @id @default(cuid())
  contactId String

  title       String
  description String?
  type        String   // call, visit, followup, etc.
  status      String   @default("pending") // pending, completed, cancelled
  dueAt       DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  completedAt DateTime?

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
}

model Note {
  id        String   @id @default(cuid())
  contactId String

  content   String
  authorId  String?  // User o Advisor
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
}

model Assignment {
  id        String   @id @default(cuid())
  contactId String
  advisorId String

  assignedAt DateTime @default(now())
  assignedBy String?   // userId que asignó
  reason     String?
  status     String    @default("active") // active, transferred, closed

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  advisor Advisor @relation(fields: [advisorId], references: [id], onDelete: Cascade)
}

// =============================================================================
// AUDITORÍA E INTEGRACIONES
// =============================================================================

model AuditEvent {
  id        String   @id @default(cuid())
  accountId String

  entityType String   // contact, conversation, message, etc.
  entityId   String
  action     String   // created, updated, deleted, assigned
  actorId    String?  // userId o "system"
  actorType  String?  // user, system, integration
  changes    Json?    // diff o detalles
  metadata   Json?

  createdAt DateTime @default(now())

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)
}

model Integration {
  id        String   @id @default(cuid())
  accountId String

  type     String   // crm, whatsapp, meta_lead_ads
  provider String?  // salesforce, hubspot, etc.
  config   Json     // credenciales encriptadas, config
  status   String   @default("active")
  metadata Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)
}
