// Kite Prospect - Esquema de base de datos
// Fuente de verdad: PRODUCT_DEFINITION.md

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// =============================================================================
// TENANCY / CUENTAS
// =============================================================================

model Account {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  status    String   @default("active") // active, suspended, trial
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Configuración básica por cuenta
  config Json? // settings comercialmente configurables

  users         User[]
  advisors      Advisor[]
  contacts      Contact[]
  properties    Property[]
  conversations Conversation[]
  integrations  Integration[]
  followUpPlans FollowUpPlan[]
  auditEvents   AuditEvent[]
}

model User {
  id        String   @id @default(cuid())
  accountId String
  email     String
  password  String   // hasheado con bcrypt
  name      String?
  role      String   // admin, coordinator, advisor
  status    String   @default("active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  account  Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  advisors Advisor[]

  @@unique([accountId, email])
}

model Advisor {
  id        String   @id @default(cuid())
  accountId String
  userId    String?
  name      String
  email     String?
  phone     String?
  status    String   @default("active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  account     Account      @relation(fields: [accountId], references: [id], onDelete: Cascade)
  user        User?        @relation(fields: [userId], references: [id])
  assignments Assignment[]
}

// =============================================================================
// CONTACTOS Y CONVERSACIONES
// =============================================================================

model Contact {
  id        String   @id @default(cuid())
  accountId String

  // Identificación
  email     String?
  phone     String?
  name      String?
  externalId String? // ID en CRM externo

  // Perfil declarado (Fase 1)
  declaredProfile Json?

  // Estados del funnel
  conversationalStage String @default("new") // new, answered, identified, profiled_partial, profiled_useful, consent_obtained, followup_active
  commercialStage     String @default("exploratory") // exploratory, prospect, real_lead, blocked, hot, assigned, visit_scheduled, opportunity_active, paused, lost, won

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  account        Account          @relation(fields: [accountId], references: [id], onDelete: Cascade)
  conversations  Conversation[]
  searchProfiles SearchProfile[]
  leadScores     LeadScore[]
  leadQualifications LeadQualification[]
  consents       Consent[]
  tasks          Task[]
  notes          Note[]
  assignments    Assignment[]
  recommendations Recommendation[]
  propertyMatches PropertyMatch[]
  followUpSequences FollowUpSequence[]
}

model Conversation {
  id        String   @id @default(cuid())
  accountId String
  contactId String

  channel   String   // web_widget, landing, whatsapp, form
  channelId String?  // ID externo del canal (ej: wa_id)
  status    String   @default("active") // active, closed, archived

  /// Última vez que el equipo abrió el hilo en inbox (no afecta orden por updatedAt si se actualiza vía SQL raw).
  lastReadAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  account   Account   @relation(fields: [accountId], references: [id], onDelete: Cascade)
  contact   Contact   @relation(fields: [contactId], references: [id], onDelete: Cascade)
  messages  Message[]
}

model Message {
  id             String   @id @default(cuid())
  conversationId String

  direction String  // inbound, outbound
  content   String
  channel   String  // web, whatsapp, etc.

  // WhatsApp: estados, plantillas, costos
  status       String?  // sent, delivered, read, failed
  templateId   String?
  metadata     Json?

  createdAt DateTime @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
}

// =============================================================================
// PERFIL Y MATCHING
// =============================================================================

model SearchProfile {
  id        String   @id @default(cuid())
  contactId String

  // Perfil de búsqueda declarado/inferido
  intent      String?   // compra, renta, inversión
  propertyType String?  // departamento, casa, terreno
  zone        String?
  minPrice    Decimal?  @db.Decimal(15, 2)
  maxPrice    Decimal?  @db.Decimal(15, 2)
  bedrooms    Int?
  bathrooms   Int?
  extra       Json?     // requisitos adicionales
  source      String    @default("declared") // declared, inferred
  confidence  Float?    // 0-1 para inferidos

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
}

model Property {
  id        String   @id @default(cuid())
  accountId String

  title       String
  description String?
  type        String   // departamento, casa, terreno
  intent      String   // venta, renta
  zone        String?
  address     String?
  price       Decimal  @db.Decimal(15, 2)
  bedrooms    Int?
  bathrooms   Int?
  area        Decimal? @db.Decimal(10, 2)
  status      String   @default("available") // available, reserved, sold, rented, withdrawn

  // Ingesta KiteProp / portales (XML full + JSON delta Proppit)
  externalSource    String? // p.ej. kiteprop
  externalId        String? // id en el feed
  importFingerprint String? // sha256 payload estable; evita escrituras si no cambió
  amenities         Json? // mapa nombre → boolean o estructura del portal
  city              String?
  province          String?
  country           String?   @default("AR")
  currency          String?   @default("ARS")
  surfaceTotal      Decimal?  @db.Decimal(12, 2)
  surfaceCovered    Decimal?  @db.Decimal(12, 2)
  rooms             Int? // ambientes
  latitude          Decimal?  @db.Decimal(12, 9)
  longitude         Decimal?  @db.Decimal(12, 9)
  feedLastSeenAt    DateTime?
  feedRemovedAt     DateTime?
  // Fecha/hora de última modición reportada por el feed (JSON/XML), si viene en el aviso.
  externalFeedUpdatedAt DateTime?

  metadata Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  account        Account          @relation(fields: [accountId], references: [id], onDelete: Cascade)
  propertyMatches PropertyMatch[]
  recommendations Recommendation[]

  @@index([accountId, externalSource])
  @@unique([accountId, externalSource, externalId], name: "property_account_external_key")
}

model PropertyMatch {
  id         String   @id @default(cuid())
  contactId  String
  propertyId String

  score      Float    // 0-100 matching score
  reason     String?  // por qué coincide
  sentAt     DateTime? // cuándo se recomendó
  feedback   String?  // interested, not_interested, viewed

  createdAt DateTime @default(now())

  contact  Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([contactId, propertyId])
}

model Recommendation {
  id         String   @id @default(cuid())
  contactId  String
  propertyId String

  channel    String   // whatsapp, email, widget
  status     String   @default("sent") // sent, delivered, opened, clicked
  sentAt     DateTime @default(now())

  contact  Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)
  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
}

// =============================================================================
// SCORING Y CALIFICACIÓN
// =============================================================================

model LeadScore {
  id        String   @id @default(cuid())
  contactId String

  // Sub-scores (0-100 cada uno)
  intentScore     Float @default(0)
  readinessScore  Float @default(0)
  fitScore        Float @default(0)
  engagementScore Float @default(0)

  totalScore Float @default(0) // combinación ponderada
  version    Int   @default(1)

  createdAt DateTime @default(now())

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
}

model LeadQualification {
  id        String   @id @default(cuid())
  contactId String

  qualified  Boolean
  reason     String?
  criteria   Json?   // detalle de criterios aplicados
  source     String  // rule, ai, manual

  createdAt DateTime @default(now())

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
}

// =============================================================================
// SEGUIMIENTO
// =============================================================================

model FollowUpPlan {
  id        String   @id @default(cuid())
  accountId String

  name        String
  description String?
  intensity   String   @default("medium") // low, medium, high
  maxAttempts Int     @default(10)
  sequence    Json    // pasos configurables
  triggers    Json?   // cuándo activar (score, stage, etc.)
  reactivateOnNewProperties Boolean @default(false)

  status    String   @default("active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  account  Account           @relation(fields: [accountId], references: [id], onDelete: Cascade)
  sequences FollowUpSequence[]
}

model FollowUpSequence {
  id             String   @id @default(cuid())
  contactId      String
  followUpPlanId String

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  status       String   @default("active") // active, paused, completed, closed
  currentStep  Int      @default(0)
  attempts     Int      @default(0)
  nextAttemptAt DateTime?

  startedAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  plan    FollowUpPlan    @relation(fields: [followUpPlanId], references: [id], onDelete: Cascade)
  attemptsList FollowUpAttempt[]
}

model FollowUpAttempt {
  id         String   @id @default(cuid())
  sequenceId String

  step       Int
  channel    String
  objective  String?  // objetivo del intento
  outcome    String?  // success, no_response, opt_out, etc.
  metadata   Json?

  attemptedAt DateTime @default(now())

  sequence FollowUpSequence @relation(fields: [sequenceId], references: [id], onDelete: Cascade)
}

// =============================================================================
// CONSENTIMIENTO
// =============================================================================

model Consent {
  id        String   @id @default(cuid())
  contactId String

  channel   String   // whatsapp, email, etc.
  granted   Boolean
  grantedAt DateTime?
  revokedAt DateTime?
  purpose   String?  // marketing, followup, etc.

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
}

// =============================================================================
// CRM BÁSICO
// =============================================================================

model Task {
  id        String   @id @default(cuid())
  contactId String

  title       String
  description String?
  type        String   // call, visit, followup, etc.
  status      String   @default("pending") // pending, completed, cancelled
  dueAt       DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  completedAt DateTime?

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
}

model Note {
  id        String   @id @default(cuid())
  contactId String

  content   String
  authorId  String?  // User o Advisor
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
}

model Assignment {
  id        String   @id @default(cuid())
  contactId String
  advisorId String

  assignedAt DateTime @default(now())
  assignedBy String?   // userId que asignó
  reason     String?
  status     String    @default("active") // active, transferred, closed

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  advisor Advisor @relation(fields: [advisorId], references: [id], onDelete: Cascade)
}

// =============================================================================
// AUDITORÍA E INTEGRACIONES
// =============================================================================

model AuditEvent {
  id        String   @id @default(cuid())
  accountId String

  entityType String   // contact, conversation, message, etc.
  entityId   String
  action     String   // created, updated, deleted, assigned
  actorId    String?  // userId o "system"
  actorType  String?  // user, system, integration
  changes    Json?    // diff o detalles
  metadata   Json?

  createdAt DateTime @default(now())

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)
}

model Integration {
  id        String   @id @default(cuid())
  accountId String

  type     String   // crm, whatsapp, meta_lead_ads
  provider String?  // salesforce, hubspot, etc.
  config   Json     // credenciales encriptadas, config
  status   String   @default("active")
  metadata Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)
}
