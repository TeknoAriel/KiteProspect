{
  "name": "kite-prospect",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w @kite-prospect/web",
    "build": "npm run build -w @kite-prospect/web",
    "start": "npm run start -w @kite-prospect/web",
    "lint": "npm run lint -w @kite-prospect/web",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "npm run typecheck -w @kite-prospect/web && npm run typecheck -w @kite-prospect/db",
    "test": "npm run test -w @kite-prospect/web",
    "verify": "npm run lint && npm run typecheck && npm run test && npm run build",
    "build:vercel": "npm run db:migrate:deploy:raw && npm run db:seed:raw && npm run build -w @kite-prospect/web",
    "db:generate": "npm run generate -w @kite-prospect/db",
    "db:migrate": "dotenv -e .env -- npm run migrate -w @kite-prospect/db",
    "db:migrate:deploy": "dotenv -e .env -- npm run migrate:deploy -w @kite-prospect/db",
    "db:migrate:deploy:raw": "npm run migrate:deploy -w @kite-prospect/db",
    "db:seed:raw": "npm run seed -w @kite-prospect/db",
    "db:push": "dotenv -e .env -- npm run push -w @kite-prospect/db",
    "db:seed": "dotenv -e .env -- npm run seed -w @kite-prospect/db",
    "db:studio": "dotenv -e .env -- npm run studio -w @kite-prospect/db",
    "db:reset": "dotenv -e .env -- npm run reset -w @kite-prospect/db",
    "postinstall": "npm run db:generate",
    "test:ai": "dotenv -e .env -- npx tsx --tsconfig apps/web/tsconfig.json apps/web/scripts/test-ai-next-action.ts",
    "kiteprop:import": "dotenv -e .env -- npx tsx --tsconfig apps/web/tsconfig.json apps/web/scripts/kiteprop-import.ts",
    "kiteprop:import:last-week": "dotenv -e .env -- npx tsx --tsconfig apps/web/tsconfig.json apps/web/scripts/kiteprop-import.ts --days=7",
    "kiteprop:import:fixture-demo": "dotenv -e .env -e apps/web/fixtures/kiteprop-fixture.env -- npx tsx --tsconfig apps/web/tsconfig.json apps/web/scripts/kiteprop-import.ts --days=7",
    "kiteprop:check-api": "dotenv -e .env -- npx tsx --tsconfig apps/web/tsconfig.json apps/web/scripts/kiteprop-check-api.ts",
    "git:push:kiteprop": "git push kiteprop main",
    "worker": "npm run worker -w @kite-prospect/web",
    "demo:up": "docker compose -f docker-compose.demo.yml up -d && echo Listo: Redis en 6379. Siguiente: REDIS_URL en .env, npm run db:migrate, npm run db:seed, npm run dev y npm run worker (ver docs/decisions/slice-activation-local-demo.md)"
  },
  "devDependencies": {
    "dotenv-cli": "^7.4.4",
    "prettier": "^3.4.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20"
  }
}
