# Raíz del monorepo — copiar a .env (ver docs/setup-local.md)
# Prisma y scripts db:* cargan estas variables desde la raíz (dotenv-cli).

DATABASE_URL="postgresql://user:password@localhost:5432/kite_prospect?schema=public"

# NextAuth (requerido para autenticación)
# Generar con: openssl rand -base64 32
AUTH_SECRET="cambiar-por-secreto-generado"

# URL pública de la app (recomendado en producción)
# AUTH_URL="https://tu-dominio.com"

# API pública POST /api/contacts/create (formularios / landings)
# Opcional si generás claves por cuenta en /dashboard/account/capture-api-keys (Bearer kp_…).
# Generar con: openssl rand -base64 32
CAPTURE_API_SECRET="cambiar-por-secreto-de-captura"

# Formulario demo en /lead (sin exponer secreto en el cliente)
# ENABLE_PUBLIC_LEAD_FORM="true"

# Límite suave por IP (memoria; varias instancias serverless = límites independientes)
# CAPTURE_RATE_LIMIT_MAX=30
# CAPTURE_RATE_LIMIT_WINDOW_SEC=60

# Login / NextAuth — POST a /api/auth/* (anti fuerza bruta; L23)
# AUTH_RATE_LIMIT_MAX=20
# AUTH_RATE_LIMIT_WINDOW_SEC=60

# Redis (opcional: worker BullMQ / Fase 2 — ver docs/decisions/slice-s06-job-runner-followups.md)
# REDIS_URL="redis://localhost:6379"

# Seguimientos automáticos — cron Vercel (S07)
# Obligatorio para invocar el cron manualmente; también debe existir en Vercel para producción.
# CRON_SECRET="generar-con-openssl-rand-base64-32"
# FOLLOW_UP_CRON_BATCH_LIMIT=25
# Horas tras el último mensaje saliente sin respuesta entrante para rama "no_response" en cron (matriz).
# FOLLOW_UP_NO_RESPONSE_HOURS=48
# Saltar pasos de seguimiento cuando el perfil ya cubre la etapa de la matriz (default activo). Desactivar: false
# FOLLOW_UP_MATRIX_SKIP_ENABLED=true

# Inventario: las URLs de feed NO van en .env; se cargan por tenant en
# /dashboard/account/property-feeds (JSON/XML). Referencia local habitual (estructura estable):
# https://static.kiteprop.com/kp/difusions/f89cbd8ca785fc34317df63d29ab8ea9d68a7b1c/properstar.json
# Sync manual: GET /api/cron/kiteprop-property-feed con Authorization: Bearer CRON_SECRET (ver docs/setup-local.md).

# Email transaccional (seguimiento por canal "email" en planes JSON) — Resend
# https://resend.com — dominio/remitente verificados
# RESEND_API_KEY=re_...
# FOLLOW_UP_FROM_EMAIL="Nombre <notificaciones@tudominio.com>"
# FOLLOW_UP_EMAIL_SUBJECT_PREFIX="Seguimiento"

# SMS seguimiento (canal "sms" en planes JSON) — Twilio (por defecto) o Telnyx (F3-E5+ L20)
# SMS_PROVIDER=twilio
# Twilio: https://www.twilio.com/docs/sms — número remitente E.164 verificado
# TWILIO_ACCOUNT_SID=ACxxxxxxxx
# TWILIO_AUTH_TOKEN=...
# TWILIO_FROM_NUMBER=+1234567890
# Telnyx (si SMS_PROVIDER=telnyx): https://developers.telnyx.com/docs/messaging/messages/send-message
# TELNYX_API_KEY=KEYxxxxxxxx
# TELNYX_FROM_NUMBER=+12025550100

# Meta Lead Ads — webhook F2-E6 (GET verify + POST leadgen). Ver docs/manual-actions-required.md §6b.
# META_LEAD_WEBHOOK_VERIFY_TOKEN=token-mismo-que-en-meta
# Opcional en producción: firma POST X-Hub-Signature-256 (App Secret de la app en Meta for Developers).
# META_LEAD_WEBHOOK_APP_SECRET=...

# WhatsApp Cloud API (Meta) — webhook S08 (ver docs/decisions/slice-s08-whatsapp-webhook.md)
# WHATSAPP_ACCOUNT_SLUG=demo
# WHATSAPP_VERIFY_TOKEN=token-de-verificacion-meta
# WHATSAPP_APP_SECRET=app-secret-para-firma-x-hub-signature-256

# WhatsApp Cloud API (Meta) — envío saliente S09 (ver docs/decisions/slice-s09-whatsapp-outbound.md)
# WHATSAPP_PHONE_NUMBER_ID=id-del-numero-en-graph
# WHATSAPP_ACCESS_TOKEN=token-de-acceso-de-la-app
# WHATSAPP_GRAPH_VERSION=v21.0

# IA conversacional S10 (dual provider) — ver docs/decisions/slice-s10-conversational-ai.md
# Versión de prompt / trazabilidad (S11) — ver docs/decisions/slice-s11-conversational-handoff-rules.md
# AI_CONVERSATION_PROMPT_VERSION=s11-v1
# AI_PROVIDER=gemini
#
# Gemini (recomendado por defecto)
# GEMINI_API_KEY=AIza...
# Default en código: gemini-2.5-flash-lite (liviano / free tier). Alternativas: gemini-2.5-flash, etc.
# GEMINI_MODEL=gemini-2.5-flash-lite
#
# OpenAI (alternativo)
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini
